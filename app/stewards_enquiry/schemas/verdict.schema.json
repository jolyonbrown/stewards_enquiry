{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/stewards-enquiry/verdict.schema.json",
  "title": "Steward's Enquiry triage verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "verdict",
    "confidence",
    "severity_assessment",
    "summary",
    "evidence",
    "proposed_actions",
    "escalate_to_human"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "true_positive",
        "false_positive",
        "benign_true_positive",
        "needs_human"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "severity_assessment": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "informational"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800,
      "description": "Plain-language summary for a SOC analyst. Max 4 sentences."
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "observation"],
        "properties": {
          "tool": {
            "type": "string",
            "enum": ["get_finding", "lookup_ip", "query_cloudtrail"]
          },
          "input_digest": {
            "type": "string",
            "description": "Short digest of the tool input, for audit correlation"
          },
          "observation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400
          }
        }
      }
    },
    "proposed_actions": {
      "type": "array",
      "description": "Empty array is valid and expected for FP / needs_human verdicts.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "target",
          "justification",
          "risk_if_wrong",
          "requires_approval",
          "status"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "isolate_instance_sg",
              "stop_instance",
              "revoke_iam_sessions",
              "disable_access_key",
              "block_ip_nacl",
              "quarantine_snapshot",
              "no_action"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "Resource identifier the action applies to (instance id, access key id, IP, etc.)"
          },
          "justification": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400
          },
          "risk_if_wrong": {
            "type": "string",
            "minLength": 1,
            "maxLength": 400,
            "description": "What breaks if this proposal is approved and the verdict was wrong"
          },
          "requires_approval": {
            "const": true
          },
          "status": {
            "const": "pending_approval"
          }
        }
      }
    },
    "escalate_to_human": {
      "type": "boolean"
    },
    "model_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    }
  }
}
